---
import Layout from '../layouts/Layout.astro';
import aboutPhoto from '../assets/photos/about me image.png';

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout title="Home Page">
  <main class="container">
    
    <section class="profile">
      
      <div class="profile__media">
        <img 
          src={aboutPhoto.src} 
          alt="Yash Shah - Software Engineering Student" 
          class="profile__image profile__image--featured" 
        />
      </div>

      <div class="profile__content">
        <!-- <h1 class="profile__title">About Me | Software Engineering</h1> -->
        <p class="profile__description">
          Hi, I'm Yash and I am a final year Software Engineering student at the
University of Technology Sydney (UTS). I'm someone who is
passionate about problem-solving and strategic thinking, which is
what drew me to software engineering. I enjoy the process of breaking
down complex, real-world problems into smaller, more manageable
pieces and building creative solutions to them.
        </p>
        <p class="profile__description">
          I have experience working in various programming languages and
frameworks, including JavaScript, Ruby, and C++. I have also worked
on different projects, ranging from web development to an AI-RAG
project. I am always eager to learn new technologies and apply these
in the real world, where I can make a meaningful impact.
        </p>
      </div>

    </section>

  </main>
</Layout>
