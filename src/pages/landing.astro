---
// 1. Script Section (Frontmatter)
import MainLayout from '../layouts/Layout.astro';


const pageTitle = "About Me | My Portfolio";

---

<MainLayout title={pageTitle}>
  <main>
    <section class="about-me">
      <h1>About Me | Software Engineering</h1>
      <p>
        Hi, I'm Yash and I am a final year Software Engineering student at the University of Technology Sydney (UTS). I'm someone who is passionate about problem-solving and strategic thinking, 
        which is what drew me to software engineering. I enjoy the process of breaking down complex, real-world problems into smaller, more manageable pieces and building creative solutions to them.
      </p>
      <p>
        I have experience working in various programming languages and frameworks, including JavaScript, Ruby, and C++. I have also worked on different projects, ranging from web development to an AI-RAG project. 
        I am always eager to learn new technologies and apply these in the real world, where I can make a meaningful impact.
      </p>
    </section>

    <section class="cta">
      <p>Want to chat about a project?</p>
      <!-- <ContactButton /> -->
    </section>
  </main>
</MainLayout>

<style>
  /* These styles only apply to THIS page */
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
    line-height: 1.6;
  }
  h1 { color: #4f46e5; font-size: 2.5rem; }
  ul { display: flex; gap: 1rem; list-style: none; padding: 0; }
  li { background: #eee; padding: 0.5rem 1rem; border-radius: 8px; }
</style>